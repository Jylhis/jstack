#!/usr/bin/env bash
# jstack-telemetry-sync — sync local JSONL events to PostHog
#
# Fire-and-forget, backgrounded, rate-limited to once per 5 minutes.
# Strips local-only fields before sending. Respects privacy tiers.
# Posts to the PostHog /batch/ endpoint.
#
# Env overrides (for testing):
#   JSTACK_STATE_DIR           — override ~/.jstack state directory
#   JSTACK_DIR                 — override auto-detected jstack root
#   JSTACK_POSTHOG_HOST        — override PostHog host URL
#   JSTACK_POSTHOG_API_KEY     — override PostHog project API key
set -uo pipefail

JSTACK_DIR="${JSTACK_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${JSTACK_STATE_DIR:-$HOME/.jstack}"
ANALYTICS_DIR="$STATE_DIR/analytics"
JSONL_FILE="$ANALYTICS_DIR/skill-usage.jsonl"
CURSOR_FILE="$ANALYTICS_DIR/.last-sync-line"
RATE_FILE="$ANALYTICS_DIR/.last-sync-time"
CONFIG_CMD="$JSTACK_DIR/bin/jstack-config"

# Source PostHog config if not overridden by env
if [ -z "${JSTACK_POSTHOG_HOST:-}" ] && [ -f "$JSTACK_DIR/posthog/config.sh" ]; then
  . "$JSTACK_DIR/posthog/config.sh"
fi
POSTHOG_HOST="${JSTACK_POSTHOG_HOST:-}"
POSTHOG_API_KEY="${JSTACK_POSTHOG_API_KEY:-}"

# ─── Pre-checks ──────────────────────────────────────────────
# No PostHog host configured yet → exit silently
[ -z "$POSTHOG_HOST" ] && exit 0

# No JSONL file → nothing to sync
[ -f "$JSONL_FILE" ] || exit 0

# Rate limit: once per 5 minutes
if [ -f "$RATE_FILE" ]; then
  STALE=$(find "$RATE_FILE" -mmin +5 2>/dev/null || true)
  [ -z "$STALE" ] && exit 0
fi

# ─── Read tier ───────────────────────────────────────────────
TIER="$("$CONFIG_CMD" get telemetry 2>/dev/null || true)"
TIER="${TIER:-off}"
[ "$TIER" = "off" ] && exit 0

# ─── Read cursor ─────────────────────────────────────────────
CURSOR=0
if [ -f "$CURSOR_FILE" ]; then
  CURSOR="$(cat "$CURSOR_FILE" 2>/dev/null | tr -d ' \n\r\t')"
  # Validate: must be a non-negative integer
  case "$CURSOR" in *[!0-9]*) CURSOR=0 ;; esac
fi

# Safety: if cursor exceeds file length, reset
TOTAL_LINES="$(wc -l < "$JSONL_FILE" | tr -d ' \n\r\t')"
if [ "$CURSOR" -gt "$TOTAL_LINES" ] 2>/dev/null; then
  CURSOR=0
fi

# Nothing new to sync
[ "$CURSOR" -ge "$TOTAL_LINES" ] 2>/dev/null && exit 0

# ─── Read unsent lines ───────────────────────────────────────
SKIP=$(( CURSOR + 1 ))
UNSENT="$(tail -n "+$SKIP" "$JSONL_FILE" 2>/dev/null || true)"
[ -z "$UNSENT" ] && exit 0

# ─── Generate anonymous distinct_id for anonymous tier ───────
ANON_DID=""
if [ "$TIER" = "anonymous" ]; then
  if command -v uuidgen >/dev/null 2>&1; then
    ANON_DID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  elif [ -r /proc/sys/kernel/random/uuid ]; then
    ANON_DID="$(cat /proc/sys/kernel/random/uuid)"
  else
    ANON_DID="anon-$(od -An -tx1 -N16 /dev/urandom 2>/dev/null | tr -d ' \n')"
  fi
fi

# ─── Strip local-only fields and build PostHog batch ─────────
BATCH=""
FIRST=true
COUNT=0

while IFS= read -r LINE; do
  # Skip empty or malformed lines
  [ -z "$LINE" ] && continue
  echo "$LINE" | grep -q '^{' || continue

  # Strip local-only fields (handle field appearing first, middle, or last in JSON)
  CLEAN="$(echo "$LINE" | sed -E \
    -e 's/"(_repo_slug|_branch|repo)":"[^"]*",?//g' \
    -e 's/,\"(_repo_slug|_branch|repo)\":\"[^\"]*\"//g')"

  # Extract event_type and ts for PostHog top-level fields
  EVENT_TYPE="$(echo "$CLEAN" | grep -o '"event_type":"[^"]*"' | head -1 | sed 's/"event_type":"//;s/"//')"
  TS="$(echo "$CLEAN" | grep -o '"ts":"[^"]*"' | head -1 | sed 's/"ts":"//;s/"//')"

  # Determine distinct_id based on tier
  if [ "$TIER" = "community" ]; then
    DID="$(echo "$CLEAN" | grep -o '"installation_id":"[^"]*"' | head -1 | sed 's/"installation_id":"//;s/"//')"
    [ -z "$DID" ] && DID="$ANON_DID"
  else
    # Anonymous tier: use per-batch random ID, strip installation_id
    DID="$ANON_DID"
    CLEAN="$(echo "$CLEAN" | sed -E 's/"installation_id":(\"[^\"]*\"|null),?//g; s/,"installation_id":(\"[^\"]*\"|null)//g')"
  fi

  # Remove event_type and ts from properties (they become top-level PostHog fields)
  PROPS="$(echo "$CLEAN" | sed \
    -e 's/"event_type":"[^"]*",//g' \
    -e 's/,"event_type":"[^"]*"//g' \
    -e 's/"ts":"[^"]*",//g' \
    -e 's/,"ts":"[^"]*"//g')"

  # Build PostHog event object
  PH_EVENT="{\"event\":\"${EVENT_TYPE:-skill_run}\",\"distinct_id\":\"${DID}\",\"timestamp\":\"${TS}\",\"properties\":${PROPS}}"

  if [ "$FIRST" = "true" ]; then
    FIRST=false
  else
    BATCH="$BATCH,"
  fi
  BATCH="$BATCH$PH_EVENT"
  COUNT=$(( COUNT + 1 ))

  # Batch size limit
  [ "$COUNT" -ge 100 ] && break
done <<< "$UNSENT"

# Nothing to send after filtering
[ "$COUNT" -eq 0 ] && exit 0

# ─── POST to PostHog /batch/ ────────────────────────────────
RESP_FILE="$(mktemp /tmp/jstack-sync-XXXXXX 2>/dev/null || echo "/tmp/jstack-sync-$$")"
trap 'rm -f "$RESP_FILE"' EXIT
HTTP_CODE="$(curl -s -w '%{http_code}' --max-time 10 \
  -X POST "${POSTHOG_HOST}/batch/" \
  -H "Content-Type: application/json" \
  -o "$RESP_FILE" \
  -d "{\"api_key\":\"${POSTHOG_API_KEY}\",\"batch\":[${BATCH}]}" 2>/dev/null || echo "000")"

# ─── Update cursor on success (2xx) ─────────────────────────
case "$HTTP_CODE" in
  2*)
    NEW_CURSOR=$(( CURSOR + COUNT ))
    echo "$NEW_CURSOR" > "$CURSOR_FILE" 2>/dev/null || true
    ;;
esac

# Update rate limit marker
touch "$RATE_FILE" 2>/dev/null || true

exit 0
