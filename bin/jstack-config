#!/usr/bin/env bash
# jstack-config — read/write ~/.jstack/config.yaml
#
# Usage:
#   jstack-config get <key>          — read a config value
#   jstack-config set <key> <value>  — write a config value
#   jstack-config list               — show all config
#
# Env overrides (for testing):
#   JSTACK_STATE_DIR  — override ~/.jstack state directory
set -euo pipefail

STATE_DIR="${JSTACK_STATE_DIR:-$HOME/.jstack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: jstack-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: jstack-config set <key> <value>}"
    VALUE="${3:?Usage: jstack-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      # Portable in-place edit (BSD sed uses -i '', GNU sed uses -i without arg)
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: jstack-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
