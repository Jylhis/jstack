#!/usr/bin/env bash
# jstack setup — build browser binary + register skills with Claude Code / Codex
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install it: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

INSTALL_JSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_JSTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_JSTACK_DIR")"
BROWSE_BIN="$SOURCE_JSTACK_DIR/browse/dist/browse"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_JSTACK="$CODEX_SKILLS/jstack"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
SKILL_PREFIX_FLAG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, kiro, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    SKILL_PREFIX=1; SKILL_PREFIX_FLAG=1; shift ;;
    --no-prefix) SKILL_PREFIX=0; SKILL_PREFIX_FLAG=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|kiro|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, kiro, or auto)" >&2; exit 1 ;;
esac

# ─── Resolve skill prefix preference ─────────────────────────
# Priority: CLI flag > saved config > interactive prompt (or flat default for non-TTY)
JSTACK_CONFIG="$SOURCE_JSTACK_DIR/bin/jstack-config"
if [ "$SKILL_PREFIX_FLAG" -eq 0 ]; then
  _saved_prefix="$("$JSTACK_CONFIG" get skill_prefix 2>/dev/null || true)"
  if [ "$_saved_prefix" = "true" ]; then
    SKILL_PREFIX=1
  elif [ "$_saved_prefix" = "false" ]; then
    SKILL_PREFIX=0
  else
    # No saved preference — prompt interactively (or default flat for non-TTY)
    if [ -t 0 ]; then
      echo ""
      echo "Skill naming: how should jstack skills appear?"
      echo ""
      echo "  1) Short names: /qa, /ship, /review"
      echo "     Recommended. Clean and fast to type."
      echo ""
      echo "  2) Namespaced: /jstack-qa, /jstack-ship, /jstack-review"
      echo "     Use this if you run other skill packs alongside jstack to avoid conflicts."
      echo ""
      printf "Choice [1/2] (default: 1): "
      read -r _prefix_choice </dev/tty 2>/dev/null || _prefix_choice=""
      case "$_prefix_choice" in
        2) SKILL_PREFIX=1 ;;
        *) SKILL_PREFIX=0 ;;
      esac
    else
      SKILL_PREFIX=0
    fi
    # Save the choice for future runs
    "$JSTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
  fi
else
  # Flag was passed explicitly — persist the choice
  "$JSTACK_CONFIG" set skill_prefix "$([ "$SKILL_PREFIX" -eq 1 ] && echo true || echo false)" 2>/dev/null || true
fi

# --local: install to .claude/skills/ in the current working directory
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  if [ "$HOST" = "codex" ]; then
    echo "Error: --local is only supported for Claude Code (not Codex)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
fi

# ─── Source shared setup library ─────────────────────────────
export SOURCE_JSTACK_DIR IS_WINDOWS SKILL_PREFIX
# shellcheck source=lib/setup-lib.sh
source "$SOURCE_JSTACK_DIR/lib/setup-lib.sh"

# ─── Migration ───────────────────────────────────────────────
migrate_direct_codex_install() {
  local jstack_dir="$1"
  local codex_jstack="$2"
  local migrated_dir="$HOME/.jstack/repos/jstack"

  [ "$jstack_dir" = "$codex_jstack" ] || return 0
  [ -L "$jstack_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$jstack_dir" ]; then
    echo "jstack setup failed: direct Codex install detected at $jstack_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  echo "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$jstack_dir" "$migrated_dir"
  SOURCE_JSTACK_DIR="$migrated_dir"
  INSTALL_JSTACK_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_JSTACK_DIR")"
  BROWSE_BIN="$SOURCE_JSTACK_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_JSTACK_DIR" "$CODEX_JSTACK"
fi

# ─── 1. Build browse binary if needed ────────────────────────
smart_rebuild "$SOURCE_JSTACK_DIR" "$BROWSE_BIN" || exit 1

# ─── 1b. Generate .agents/ Codex skill docs ──────────────────
# bun run build already does this, but we need it when binary is fresh.
gen_agents_skill_docs "$SOURCE_JSTACK_DIR"

# ─── 2. Ensure Playwright's Chromium is available ────────────
ensure_playwright_chromium || exit 1

# ─── 3. Ensure ~/.jstack global state directory exists ───────
ensure_jstack_dirs

# ─── 4. Install for Claude (default) ─────────────────────────
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale symlinks from the opposite prefix mode
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      cleanup_old_claude_symlinks "$SOURCE_JSTACK_DIR" "$INSTALL_SKILLS_DIR"
    else
      cleanup_prefixed_claude_symlinks "$SOURCE_JSTACK_DIR" "$INSTALL_SKILLS_DIR"
    fi
    link_claude_skill_dirs "$SOURCE_JSTACK_DIR" "$INSTALL_SKILLS_DIR"
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      echo "jstack ready (project-local)."
      echo "  skills: $INSTALL_SKILLS_DIR"
    else
      echo "jstack ready (claude)."
    fi
    echo "  browse: $BROWSE_BIN"
  else
    echo "jstack ready (claude)."
    echo "  browse: $BROWSE_BIN"
    echo "  (skipped skill symlinks — not inside .claude/skills/)"
  fi
fi

# ─── 5. Install for Codex ────────────────────────────────────
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_JSTACK="$INSTALL_JSTACK_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_JSTACK_DIR" "$CODEX_JSTACK"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_JSTACK_DIR" "$CODEX_SKILLS"

  echo "jstack ready (codex)."
  echo "  browse: $BROWSE_BIN"
  echo "  codex skills: $CODEX_SKILLS"
fi

# ─── 6. Install for Kiro CLI (copy from .agents/skills, rewrite paths) ───
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_JSTACK_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create jstack dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_JSTACK="$KIRO_SKILLS/jstack"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_JSTACK" ] && rm -f "$KIRO_JSTACK"
  mkdir -p "$KIRO_JSTACK" "$KIRO_JSTACK/browse" "$KIRO_JSTACK/jstack-upgrade" "$KIRO_JSTACK/review"
  ln -snf "$SOURCE_JSTACK_DIR/bin" "$KIRO_JSTACK/bin"
  ln -snf "$SOURCE_JSTACK_DIR/browse/dist" "$KIRO_JSTACK/browse/dist"
  ln -snf "$SOURCE_JSTACK_DIR/browse/bin" "$KIRO_JSTACK/browse/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_JSTACK_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_JSTACK_DIR/ETHOS.md" "$KIRO_JSTACK/ETHOS.md"
  fi
  # jstack-upgrade skill
  if [ -f "$AGENTS_DIR/jstack-upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/jstack-upgrade/SKILL.md" "$KIRO_JSTACK/jstack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, not whole dir)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_JSTACK_DIR/review/$f" ]; then
      ln -snf "$SOURCE_JSTACK_DIR/review/$f" "$KIRO_JSTACK/review/$f"
    fi
  done

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/jstack|~/.kiro/skills/jstack|g" \
      -e "s|\.claude/skills/jstack|.kiro/skills/jstack|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_JSTACK_DIR/SKILL.md" > "$KIRO_JSTACK/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/jstack*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $JSTACK_ROOT variables.
      # Rewrite the default JSTACK_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/jstack|$HOME/.kiro/skills/jstack|g' \
          -e "s|~/.codex/skills/jstack|~/.kiro/skills/jstack|g" \
          -e "s|~/.claude/skills/jstack|~/.kiro/skills/jstack|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "jstack ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
  fi
fi

# ─── 7. Create .agents/ sidecar symlinks ─────────────────────
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_JSTACK_DIR"
fi

# ─── 8. First-time welcome + legacy cleanup ──────────────────
if [ ! -f "$HOME/.jstack/.welcome-seen" ]; then
  echo "  Welcome! Run /jstack-upgrade anytime to stay current."
  touch "$HOME/.jstack/.welcome-seen"
fi
rm -f /tmp/jstack-latest-version
